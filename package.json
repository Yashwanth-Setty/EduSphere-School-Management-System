{
  "name": "spira",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "dev:web": "pnpm --filter @spira/web dev",
    "dev:api": "pnpm --filter @spira/api dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @spira/api prisma generate",
    "db:migrate": "pnpm --filter @spira/api prisma migrate dev",
    "db:push": "pnpm --filter @spira/api prisma db push",
    "db:seed": "pnpm --filter @spira/api prisma db seed",
    "db:studio": "pnpm --filter @spira/api prisma studio"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
