NODE_ENV=development

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://app:app@localhost:5432/spira

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES=900
JWT_REFRESH_EXPIRES=604800

# OIDC/SSO (optional)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:4000/api/v1/auth/sso/callback

# Object Storage (S3-compatible)
STORAGE_BUCKET=spira-documents
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# Email
EMAIL_FROM=noreply@spira.school
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS (optional)
SMS_PROVIDER=
SMS_API_KEY=

# Payment (optional)
PAYMENT_PROVIDER=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# AI (optional, disabled by default)
AI_ENABLED=false
AI_PROVIDER=
AI_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000
