# ─── SPIRA — Environment Variables ───────────────────────────────────────────
# Copy this file to apps/api/.env  (API server)
# And:  echo "NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1" > apps/web/.env.local
#
# Variables marked [REQUIRED] must be set. [OPTIONAL] have safe defaults for dev.
# Never commit actual secrets. Use a secrets manager in production.

# ── Runtime ───────────────────────────────────────────────────────────────────

# [REQUIRED] Node environment
# Values: development | test | production
NODE_ENV=development

# [OPTIONAL] API server port
PORT=4000

# [OPTIONAL] Public app URL (used for links in emails)
APP_URL=http://localhost:3000

# [OPTIONAL] API base URL (informational)
API_URL=http://localhost:4000

# ── Database ──────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://app:app@localhost:5432/spira

# ── Cache ─────────────────────────────────────────────────────────────────────

# [OPTIONAL] Redis connection string (used for session/job queuing)
REDIS_URL=redis://localhost:6379

# ── Auth / JWT ────────────────────────────────────────────────────────────────

# [REQUIRED] JWT signing secret — minimum 32 characters, randomly generated
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# [OPTIONAL] Access token expiry in seconds (default: 900 = 15 min)
JWT_ACCESS_EXPIRES=900

# [OPTIONAL] Refresh token expiry in seconds (default: 604800 = 7 days)
JWT_REFRESH_EXPIRES=604800

# ── CORS ──────────────────────────────────────────────────────────────────────

# [REQUIRED in production] Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# ── OIDC / SSO (optional) ─────────────────────────────────────────────────────

# Leave blank to disable SSO. OIDC_ISSUER must be a discoverable OpenID provider.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:4000/api/v1/auth/sso/callback

# ── Object Storage (S3-compatible) ────────────────────────────────────────────

# Used by the Documents module to store uploaded files.
# Leave blank in dev — document metadata is stored but no actual upload occurs.
STORAGE_BUCKET=spira-documents
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
# Leave STORAGE_ENDPOINT blank for AWS S3; set for MinIO, Cloudflare R2, etc.
STORAGE_ENDPOINT=

# ── Email ─────────────────────────────────────────────────────────────────────

# [OPTIONAL] Sender address for all outbound email
EMAIL_FROM=noreply@spira.school

# [OPTIONAL] Provider: smtp | sendgrid | ses
EMAIL_PROVIDER=smtp

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── SMS (optional) ────────────────────────────────────────────────────────────

# Provider: twilio | aws-sns | vonage
SMS_PROVIDER=
SMS_API_KEY=

# ── Payments (optional) ───────────────────────────────────────────────────────

# Provider: stripe | razorpay | paypal
PAYMENT_PROVIDER=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# ── AI Insights ───────────────────────────────────────────────────────────────

# The built-in attendance risk and performance scoring runs without an LLM.
# Set AI_ENABLED=true and configure a provider only if extending to generative AI.
AI_ENABLED=false

# Provider: openai | anthropic | azure-openai
AI_PROVIDER=
AI_API_KEY=
